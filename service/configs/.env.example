LABEL_ALLOWLIST=Benign
WHITELIST_IPS=
BLOCK_CONFIDENCE_THRESHOLD=0.80
LABEL_BLOCK_THRESHOLDS=Infiltration=0.90,SQL Injection=0.95
LABEL_RISK_SCORES=Infiltration=60,SQL Injection=70,Brute Force=55,DoS=50,DDoS=65,Bot=45
SENSITIVE_PORT_SCORES=22=20,53=10,445=25,3389=30
ACTION_THRESHOLDS=suspicious=25,alert=50,block_candidate=80,block=100
MIN_BLOCK_OBSERVATIONS=2
REPEAT_OBSERVATION_SCORE=15
SKIP_PRIVATE_PEER_BLOCKING=true
SUSPICIOUS_ATTACK_LABELS=Infiltration,Brute Force,SQL Injection,DoS,DDoS,Bot
SUSPICIOUS_SECONDARY_THRESHOLD=0.25
SUSPICIOUS_GAP_THRESHOLD=0.20
SUSPICIOUS_SCORE=25
SIGNATURE_ENABLED=true
SIGNATURE_RULE_SCORES=tcp-sensitive-port-probe=35,tcp-half-open-probe=25,tcp-rst-probe=20
SIGNATURE_PROBE_MAX_PACKETS=8
SIGNATURE_PROBE_MAX_PAYLOAD_BYTES=32
OPENSEARCH_ENABLED=false
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=deepfence-events
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_TIMEOUT_SECONDS=5
DEFAULT_MODEL_NAME=best_model_v6_catboost.cbm
CAPTURE_INTERFACE=eth0
CAPTURE_PACKET_COUNT=12
CAPTURE_TIMEOUT_SECONDS=10
FLOW_IDLE_TIMEOUT_SECONDS=15
LOOP_SLEEP_SECONDS=1.0
